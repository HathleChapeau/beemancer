{
  "multipart": [
    { "when": { "tinted": false }, "apply": { "model": "apica:block/pipes/item_pipe_core_t4" } },
    { "when": { "tinted": true }, "apply": { "model": "apica:block/pipes/item_pipe_core_t4_tinted" } },
    { "when": { "north": true }, "apply": { "model": "apica:block/pipes/item_pipe_side_t2", "y": 0 } },
    { "when": { "south": true }, "apply": { "model": "apica:block/pipes/item_pipe_side_t2", "y": 180 } },
    { "when": { "east": true }, "apply": { "model": "apica:block/pipes/item_pipe_side_t2", "y": 90 } },
    { "when": { "west": true }, "apply": { "model": "apica:block/pipes/item_pipe_side_t2", "y": 270 } },
    { "when": { "up": true }, "apply": { "model": "apica:block/pipes/item_pipe_side_t2", "x": 270 } },
    { "when": { "down": true }, "apply": { "model": "apica:block/pipes/item_pipe_side_t2", "x": 90, "y": 180 } },
    { "when": { "filtered": true }, "apply": { "model": "apica:block/pipes/item_pipe_filter" } }
  ]
}
